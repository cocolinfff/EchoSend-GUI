{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EchoSend",
  "version": "0.1.0",
  "identifier": "com.cocolinfff.echosendgui",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "EchoSend",
        "label": "main",
        "width": 1100,
        "height": 760,
        "minWidth": 860,
        "minHeight": 620,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
